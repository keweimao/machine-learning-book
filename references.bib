@ARTICLE{Bekenstein2003,
  author = {Jacob D. Bekenstein},
  title = {Information in the Holographic Universe},
  journal = {Scientific American},
  year = {2003},
  volume = {289},
  pages = {58--65},
  number = {2},
  month = {August},
  owner = {weimao},
  review = {However, some leading theoretical physicist have different points.
	\citeA{Bekenstein2003}, a member of the Israel Academy of Sciences
	and a former student of John Wheeler, argued that ``\textbf{thermodynamic
	entropy and Shannon entropy are conceptually equivalent}'' and that
	``\textbf{they are equal when...calculated for the same degree of
	freedom}.''


	If Bekenstein is all correct in his reasoning, then the connection
	between information and energy is clear by following the path from
	information to entropy, and from entropy to energy. More fundamentally,
	there is a current trend, initiated by John A. Wheeler of Princeton
	University, \textbf{to regard the physical world as made of information,
	with energy and matter as incidentals}.


	In an ongoing research, I proposed a novel algorithm that uses simulated
	agents in a multi-dimensional space to model collaborative filtering
	systems, or recommender systems. Using attractive and repulsive forces
	to simulate user interest levels, the agents are subject to \textsl{potential
	energy} caused by unbalanced forces. When the system approaches its
	minimal \textsl{energy}, it is capable of making accurate predictions,
	arguably more representative of \textsl{information} in the training
	data. If \textsl{information} can be depicted by \textsl{entropy}
	variation, it can be equated with ``\textsl{energy dispersal}'' in
	thermodynamic sense, rather than the information-theoretic \textsl{entropy}
	proposed by Shannon (1948). This demonstrates, although arbitrarily,
	the connection between \textsl{information} and \textsl{energy}.
	Preliminary experiments have shown promising results. Closer exploration
	of this and its application to information retrieval systems might
	be rewarding.},
  timestamp = {2009.03.14}
}

