@Article{Ke:2015,
  author="Ke, Weimao",
  title="Information-theoretic term weighting schemes for document clustering and classification",
  journal="International Journal on Digital Libraries",
  year="2015",
  month="Jun",
  day="01",
  volume="16",
  number="2",
  pages="145--159",
  abstract="We propose a new theory to quantify information in probability distributions and derive a new document representation model for text clustering and classification. By extending Shannon entropy to accommodate a non-linear relation between information and uncertainty, the proposed least information theory provides insight into how terms can be weighted based on their probability distributions in documents vs. in the collection. We derive two basic quantities for document representation: (1) LI Binary (LIB) which quantifies information due to the observation of a term's (binary) occurrence in a document; and (2) LI Frequency (LIF) which measures information for the observation of a randomly picked term from the document. The two quantities are computed based on terms' prior distributions in the entire collection and posterior distributions in a document. LIB and LIF can be used individually or combined to represent documents for text clustering and classification. Experiments on four benchmark text collections demonstrate strong performances of the proposed methods compared to classic TF*IDF. Particularly, the LIB*LIF weighting scheme, which combines LIB and LIF, consistently outperforms TF*IDF in terms of multiple evaluation metrics. The least information measure has a potentially broad range of applications beyond text clustering and classification.",
  issn="1432-1300",
  doi="10.1007/s00799-014-0121-3",
  url="https://doi.org/10.1007/s00799-014-0121-3"
}

@article{Shannon1948,
	Author = {Claude E. Shannon},
	Journal = {Bell System Technical Journal},
	Month = {July and October},
	Owner = {weimao},
	Pages = {379--423 and 623--656},
	Review = {\citeA{Shannon1948} developed information entropy as a measure for the uncertainty in a message, and its reduction Information. Here, we see information as the inverse of entropy. Shannon's entropy does not evaluate the quality and relevance of information; it only measures quantity of information. We are hopeful to have a theory that measures contextual values of information mathematically. But this is not the focus of the discussion here. The term ``entropy'' has been strictly used in thermodynamics/physics before Shannon used it in information theory. The concept, introduced by Rudolf Clausius and further developed by Ludwig Boltzmann, is associated with the amount of chaos/order/disorder in a system. In thermodynamics, it is a measure of ``the unavailability of a system's energy to do work,'' or ``the amount of wasted energy in a dynamical energy transformation from one state or form to another.'' Now, my questions is: Is there any connection between the two entropies, i.e., the thermodynamic and the information theoretic, and thus a connection between Information and one of the fundamental elements of the universe, i.e., energy. Even though Shannon was encouraged (by Van Neumann?) to use the word ``entropy'' in his information theory, the term is usually considered fundamentally different from the entropy in thermodynamics/physics. How much informtion is "produced"? If there is a one to measure information, say $H(p_1,P_2,...,p_n)$, it is reasonable to have the following properties: \begin{enumerate} \item $H$ should be continuous in the $p_i$; \item With equally likely there is more choice, or uncertainty, when there are more possible events; \item If a choice be broken down into two successive choices, the original $H$ should be wieghted sum of the individual values of $H$. \end{enumerate} The only $H$ satisfying the three above assumptions is of the form: \begin{equation} H = - K \sum^n_{i=1} p_i\log{p_i} \end{equation} where $K$ is a positive constant, which merely amounts to a choice of a unit of measure. We shall call $H = - \sum^n_{i=1} p_i\log{p_i}$ the entropy of the set of probabilities $p_1,...,p_n$. \begin{enumerate} \item $H=0$ if and only if all the $p_i$ but one are zero. Thus only when we are certain of the outcome does $H$ vanish. Otherwise $H$ is positive. \item For a given $n$, $H$ is a maximum and equal to $\log{n}$ when all the $p_i$ are equal, i.e., $\frac{1}{n}$. This is also intuitively the most uncertain situation. \item Suppose there are two events, $x$ and $y$, in question, with $m$ possibilities for the first and $n$ for the second. Let $p(i,j)$ be the probability of the joint occurrence of $i$ for the first and $j$ for the second. The entropy of the joint event is shown in Equation (\ref{eq:joint-H}). \suspend{enumerate} \begin{equation} H(x,y) = - \sum^{}_{i,j} p(i,j)\log p(i,j) \label{eq:joint-H} \end{equation} while \begin{equation} H(x) = - \sum^{}_{i,j} p(i,j)\log \sum_{j} p(i,j) \end{equation} \begin{equation} H(y) = - \sum^{}_{i,j} p(i,j)\log \sum_{i} p(i,j) \end{equation} It can be shown that (equal only when $x$ and $y$ are independent): \begin{equation} H(x,y) \leq H(x) + H(y) \end{equation} \resume{enumerate} \setcounter{enumi}{5} \item Any change toward equalization of the probabilities $p_1,p_2,...,p_n$ increases $H$; \item The uncertainty (or entropy) of the joint event $x,y$ is the uncertainty of $x$ plus the uncertainty of $y$ when $x$ is known, i.e., $H(x,y) = H(x) + H_x(y)$; \item $H(x) + H(y) \geq H(x,y) = H(x) + H_x(y) \rightarrow H(y) \geq H_x(y)$; \end{enumerate}},
	Timestamp = {2009.03.14},
	Title = {A mathematical theory of communication},
	Volume = {27},
	Year = {1948}}

@ARTICLE{Buckland1991,
  author = {Buckland, Michael K. },
  title = {Information as thing},
  journal = {Journal of the American Society for Information Science},
  year = {1991},
  volume = {42},
  pages = {351--360},
  number = {5},
  month = {January},
  citeulike-article-id = {225218},
  doi = {10.1002/(SICI)1097-4571(199106)42:5<351::AID-ASI5>3.0.CO;2-3},
  issn = {1097-4571},
  keywords = {berkeley, philosophy-of-information},
  owner = {weimao},
  priority = {0},
  review = {LIS researchers have offered various perspectives to look at what
	information is. \citeA{Buckland1991}, for instance, followed the
	information-as-thing approach to understanding a tangible meaning
	of Information Science. \citeA{Bates2006} discussed the fundamental
	forms of information and realized that, ``almost anything existing
	in the universe can be experienced as information.''


	It seems to me that Information is quite a fundamental element in
	the universe. However, \citeA{Buckland1991} quoted, ``Information
	is information, not material nor energy.'' \citeA{Bates2006} also
	quoted, ``Information is the pattern of organization of matter and
	energy.'' Yet, the term ``pattern'' does not really add to one's
	understanding of what information is.},
  timestamp = {2009.03.14}
}

